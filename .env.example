# ===== Servidor =====
PORT=4000
NODE_ENV=development

# Origens permitidas (CORS) separadas por vírgula
CORS_ORIGINS=http://localhost:3000,https://ormed-qx3s.vercel.app

# ===== Base de dados (MongoDB Atlas) =====
MONGODB_URI=mongodb+srv://utilizador:senha@cluster.mongodb.net/ormed?retryWrites=true&w=majority

# ===== Autenticação (JWT) =====
# Gere segredos fortes: openssl rand -base64 48
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-forte
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-este-outro-segredo-por-um-valor-aleatorio-forte
JWT_REFRESH_EXPIRES_IN=7d

# ===== Seed do primeiro admin =====
SEED_ADMIN_NAME=Administrador ORMED
SEED_ADMIN_EMAIL=admin@ordemdosmedicos.ao
SEED_ADMIN_PASSWORD=troque-esta-senha-no-primeiro-acesso

# ===== Cloudinary (uploads de imagens e PDFs) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== Assistente de IA (Google Gemini — nível gratuito) =====
# Obtenha a chave gratuita em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
